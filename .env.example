# 记忆库根目录（按游戏分库的文件夹都放这下面）
DATA_DIR=data

# LLM（OpenAI 兼容接口）。默认指向 DeepSeek 官方；也可换 Proma Cloud (https://api.proma.cool/v1) 等
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=填你的_key

# 整理用便宜档（批量省钱）/ 对话用强档（剧情讨论）
# DeepSeek 可选：deepseek-chat (V3) / deepseek-reasoner (R1，推理强但慢且贵)
LLM_MODEL_ORGANIZE=deepseek-chat
LLM_MODEL_CHAT=deepseek-chat

# 自动整理触发：每攒够 N 条 或 每 M 秒
ORGANIZE_BATCH_SIZE=20
ORGANIZE_INTERVAL_SEC=180

# 对话上下文：最近多少条原始台词
CHAT_RECENT_WINDOW=200
