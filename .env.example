# 记忆库根目录（按游戏分库的文件夹都放这下面）
DATA_DIR=data

# LLM（OpenAI 兼容接口）。默认指向 Proma Cloud
LLM_BASE_URL=https://api.proma.cool
LLM_API_KEY=填你的_key

# 整理用便宜档 / 对话用强档（按你的 provider 改模型名）
LLM_MODEL_ORGANIZE=deepseek-chat
LLM_MODEL_CHAT=deepseek-chat

# 自动整理触发：每攒够 N 条 或 每 M 秒
ORGANIZE_BATCH_SIZE=20
ORGANIZE_INTERVAL_SEC=180

# 对话上下文：最近多少条原始台词
CHAT_RECENT_WINDOW=200
